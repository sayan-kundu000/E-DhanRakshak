# E-Rakshak Backend Environment Variables Template
# Copy this file to .env and configure settings before launching the application.

# General settings
FLASK_ENV=development
PORT=5000

# Security secrets (Use long random character sequences in staging and production)
SECRET_KEY=develop-secret-key-replace-this-with-a-secure-random-value-in-prod
JWT_SECRET_KEY=develop-jwt-key-replace-this-with-a-secure-random-value-in-prod

# Database connection URL
# local development defaults:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/e_rakshak
# testing overrides:
TEST_DATABASE_URL=sqlite:///:memory:

# Redis configuration (Used for caching, rate limiter, and Celery broker)
REDIS_URL=redis://localhost:6379/0

# Asynchronous queue settings (Celery defaults to REDIS_URL if empty)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS settings (Comma-separated list of permitted origin addresses)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload configurations
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_BYTES=5242880
